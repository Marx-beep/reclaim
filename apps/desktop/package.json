{
  "name": "@reclaim/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop shell for Reclaim time manager web app",
  "author": "Reclaim Team",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "build": "node -e \"console.log('Use dist:win to build Windows exe')\"",
    "typecheck": "node -e \"console.log('No static typecheck in desktop shell')\"",
    "test": "node -e \"console.log('No desktop tests yet')\"",
    "dist:win": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.reclaim.desktop",
    "productName": "Reclaim 时间管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "Reclaim-Time-Manager-${version}-${arch}.exe"
    }
  }
}
