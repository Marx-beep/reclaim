{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@reclaim/database": [
        "../../packages/database/src/index.ts"
      ],
      "@reclaim/database/*": [
        "../../packages/database/src/*"
      ],
      "@reclaim/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@reclaim/domain/*": [
        "../../packages/domain/src/*"
      ],
      "@reclaim/queue": [
        "../../packages/queue/src/index.ts"
      ],
      "@reclaim/queue/*": [
        "../../packages/queue/src/*"
      ],
      "@reclaim/integrations": [
        "../../packages/integrations/src/index.ts"
      ],
      "@reclaim/integrations/*": [
        "../../packages/integrations/src/*"
      ],
      "@reclaim/recurrence": [
        "../../packages/recurrence/src/index.ts"
      ],
      "@reclaim/recurrence/*": [
        "../../packages/recurrence/src/*"
      ],
      "@reclaim/temporal": [
        "../../packages/temporal/src/index.ts"
      ],
      "@reclaim/temporal/*": [
        "../../packages/temporal/src/*"
      ],
      "@reclaim/config": [
        "../../packages/config/src/index.ts"
      ],
      "@reclaim/config/*": [
        "../../packages/config/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
